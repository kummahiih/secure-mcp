# Stage 1: Build the binary
FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY fileserver/* .
RUN go build -o mcp-server main.go

# Stage 2: Certificate Signer (The "Secure" part)
FROM alpine:3.23.3 AS signer
RUN apk add --no-cache openssl
WORKDIR /certs

# We mount the CA Key/Crt from the host ONLY during this build step
# This prevents the key from ever being stored in a layer.
RUN --mount=type=bind,source=./certs/ca.key,target=/tmp/ca.key \
    --mount=type=bind,source=./certs/ca.crt,target=/tmp/ca.crt \
    openssl genrsa -out mcp.key 2048 && \
    openssl req -new -key mcp.key -out mcp.csr -subj "/CN=mcp-server" && \
    echo "subjectAltName=DNS:mcp-server,DNS:localhost,IP:127.0.0.1" > mcp.ext && \
    openssl x509 -req -in mcp.csr -CA /tmp/ca.crt -CAkey /tmp/ca.key -CAcreateserial \
    -out mcp.crt -days 365 -sha256 -extfile mcp.ext

# Stage 3: Final Image
FROM alpine:3.23.3
RUN addgroup -g 1000 appgroup && adduser -u 1000 -G appgroup -S appuser

WORKDIR /app
# Copy the binary
COPY --from=builder /app/mcp-server .
# Copy ONLY the leaf cert and leaf key (No CA key here!)
COPY --from=signer /certs/mcp.crt /certs/mcp.key /app/certs/
# Copy public CA cert for trust chain
COPY ./certs/ca.crt /app/certs/ca.crt

RUN chown -R appuser:appgroup /app/certs && chmod 600 /app/certs/mcp.key

USER appuser
EXPOSE 8443
CMD ["./mcp-server"]